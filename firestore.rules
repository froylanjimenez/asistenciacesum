rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lista de emails con privilegio superadmin
    function isSuperAdminEmail(email) {
      return email == 'froylan.jimenez@gmail.com'
          || email == 'fjsan10@gmail.com';
    }

    // Superadmins identificados por Firebase Auth token — no dependen de Firestore
    function isSuperAdmin() {
      return request.auth != null && isSuperAdminEmail(request.auth.token.email);
    }

    // Usuario activo con documento en Firestore
    function isActivo() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo != false;
    }

    // Acceso de lectura: superadmin SIEMPRE puede leer aunque no tenga doc en Firestore
    function canRead() {
      return isSuperAdmin() || isActivo();
    }

    // Admin: superadmin siempre pasa; otros necesitan rol en Firestore
    function isAdmin() {
      return isSuperAdmin()
        || (isActivo()
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin');
    }

    // Nombre del usuario en Firestore (para compatibilidad con actividades antiguas)
    function miNombre() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nombre;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Propio perfil sin helper (evita ciclo); superadmin o usuario activo
      allow get: if request.auth != null && (request.auth.uid == uid || canRead());
      // Solo admins pueden listar usuarios (cargarDocentesAdmin)
      allow list: if isAdmin();
      // Crear: admins O superadmin creando su propio perfil si no existe
      allow create: if isAdmin() || (isSuperAdmin() && request.auth.uid == uid);
      // Actualizar: superadmin siempre; admins no pueden tocar cuentas superadmin
      allow update: if isSuperAdmin()
                    || (isAdmin() && !isSuperAdminEmail(resource.data.email));
      // Borrar: admins para cualquier cuenta excepto las de los superadmins
      allow delete: if isAdmin() && !isSuperAdminEmail(resource.data.email);
    }

    // ── Estudiantes ───────────────────────────────────────────────────────
    match /estudiantes/{estId} {
      allow read: if canRead();
      allow write: if isAdmin();
    }

    // ── Asistencia ────────────────────────────────────────────────────────
    match /asistencia/{fecha} {
      allow read: if canRead();
      allow write: if canRead();
    }

    // ── Reportes de comportamiento ────────────────────────────────────────
    match /reportes/{repId} {
      allow read: if canRead();
      allow create: if canRead();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Novedades / ausencias justificadas ───────────────────────────────
    match /novedades/{novId} {
      allow read: if canRead();
      allow create: if canRead();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Citas ─────────────────────────────────────────────────────────────
    match /citas/{citaId} {
      allow read: if canRead();
      allow create: if canRead();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Noticias / comunicados ────────────────────────────────────────────
    match /noticias/{notId} {
      allow read: if canRead();
      allow write: if isAdmin();
    }

    // ── Actividades / notas ───────────────────────────────────────────────
    match /actividades/{actId} {
      allow read: if canRead();
      allow create: if canRead();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid)
        || (isActivo() && resource.data.docenteUid == request.auth.uid)
        || (isActivo() && resource.data.docente == miNombre());
    }

    // ── Eventos / calendario institucional ───────────────────────────────
    match /eventos/{evId} {
      allow read: if canRead();
      allow create, update, delete: if isAdmin();
    }

    // ── Bloqueo por defecto ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
