rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Superadmin identificado por Firebase Auth token — no depende de Firestore
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email == 'froylan.jimenez@gmail.com';
    }

    // Usuario activo con documento en Firestore
    function isActivo() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo != false;
    }

    // Admin: superadmin siempre pasa; otros necesitan rol en Firestore
    function isAdmin() {
      return isSuperAdmin()
        || (isActivo()
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin');
    }

    // Nombre del usuario en Firestore (para compatibilidad con actividades antiguas)
    function miNombre() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nombre;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Propio perfil sin helper (evita ciclo); otros requieren isActivo
      allow get: if request.auth != null && (request.auth.uid == uid || isActivo());
      // Solo admins pueden listar usuarios (cargarDocentesAdmin)
      allow list: if isAdmin();
      // Crear: admins O superadmin creando su propio perfil si no existe
      allow create: if isAdmin() || (isSuperAdmin() && request.auth.uid == uid);
      // Actualizar: admins para cualquier cuenta excepto la del superadmin;
      //             el superadmin siempre puede actualizar su propio doc
      allow update: if (isAdmin() && resource.data.email != 'froylan.jimenez@gmail.com')
                    || (isSuperAdmin() && request.auth.uid == uid);
      // Borrar: admins para cualquier cuenta excepto la del superadmin
      allow delete: if isAdmin() && resource.data.email != 'froylan.jimenez@gmail.com';
    }

    // ── Estudiantes ───────────────────────────────────────────────────────
    match /estudiantes/{estId} {
      allow read: if isActivo();
      allow write: if isAdmin();
    }

    // ── Asistencia ────────────────────────────────────────────────────────
    match /asistencia/{fecha} {
      allow read: if isActivo();
      allow write: if isActivo();
    }

    // ── Reportes de comportamiento ────────────────────────────────────────
    match /reportes/{repId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Novedades / ausencias justificadas ───────────────────────────────
    match /novedades/{novId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Citas ─────────────────────────────────────────────────────────────
    match /citas/{citaId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Noticias / comunicados ────────────────────────────────────────────
    match /noticias/{notId} {
      allow read: if isActivo();
      allow write: if isAdmin();
    }

    // ── Actividades / notas ───────────────────────────────────────────────
    match /actividades/{actId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid)
        || (isActivo() && resource.data.docenteUid == request.auth.uid)
        || (isActivo() && resource.data.docente == miNombre());
    }

    // ── Bloqueo por defecto ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
