rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: el usuario autenticado tiene un perfil activo
    function isActivo() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo != false;
    }

    // Helper: el usuario es admin activo
    function isAdmin() {
      return isActivo()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Helper: nombre del usuario actual en Firestore
    function miNombre() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nombre;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // get (un doc): propio perfil sin helper para evitar ciclo; otros requieren isActivo
      allow get: if request.auth != null && (request.auth.uid == uid || isActivo());
      // list (query colección): solo admins (cargarDocentesAdmin)
      allow list: if isAdmin();
      // Solo admins crean/modifican/borran usuarios,
      // pero nadie puede tocar la cuenta superadmin (fjsan10@gmail.com)
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource.data.email != 'fjsan10@gmail.com';
    }

    // ── Estudiantes ───────────────────────────────────────────────────────
    match /estudiantes/{estId} {
      allow read: if isActivo();
      allow write: if isAdmin();
    }

    // ── Asistencia ────────────────────────────────────────────────────────
    match /asistencia/{fecha} {
      allow read: if isActivo();
      allow write: if isActivo();
    }

    // ── Reportes de comportamiento ────────────────────────────────────────
    match /reportes/{repId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Novedades / ausencias justificadas ───────────────────────────────
    match /novedades/{novId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Citas ─────────────────────────────────────────────────────────────
    match /citas/{citaId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Noticias / comunicados ────────────────────────────────────────────
    match /noticias/{notId} {
      allow read: if isActivo();
      allow write: if isAdmin();
    }

    // ── Actividades / notas ───────────────────────────────────────────────
    match /actividades/{actId} {
      allow read: if isActivo();
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid)
        || (isActivo() && resource.data.docenteUid == request.auth.uid)
        // Compatibilidad con actividades antiguas (sin docenteUid/creadoPor):
        // permite si el campo 'docente' coincide con el nombre del usuario actual
        || (isActivo() && resource.data.docente == miNombre());
    }

    // ── Bloqueo por defecto ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
