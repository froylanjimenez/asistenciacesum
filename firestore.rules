rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lista de emails con privilegio superadmin
    function isSuperAdminEmail(email) {
      return email == 'froylan.jimenez@gmail.com'
          || email == 'fjsan10@gmail.com';
    }

    // Superadmins identificados por Firebase Auth token — no dependen de Firestore
    function isSuperAdmin() {
      return request.auth != null && isSuperAdminEmail(request.auth.token.email);
    }

    // Usuario activo — usado solo en escrituras (evita lecturas extra en rules para reads)
    function isActivo() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo != false;
    }

    // Admin: un solo get() para leer activo + rol al mismo tiempo
    function isAdmin() {
      return isSuperAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin'
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo != false);
    }

    // Nombre del usuario en Firestore (solo para compatibilidad con actividades antiguas)
    function miNombre() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nombre;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Lectura: cualquier usuario autenticado puede leer su propio perfil;
      // admins y superadmins pueden leer cualquiera
      allow get: if request.auth != null && (request.auth.uid == uid || isAdmin() || isSuperAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSuperAdmin() && request.auth.uid == uid);
      allow update: if isSuperAdmin()
                    || (isAdmin() && !isSuperAdminEmail(resource.data.email));
      allow delete: if isAdmin() && !isSuperAdminEmail(resource.data.email);
    }

    // ── Estudiantes ───────────────────────────────────────────────────────
    // Lectura: cualquier sesión autenticada (el control de activo se hace en la app)
    // Escritura: solo admins
    match /estudiantes/{estId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Asistencia ────────────────────────────────────────────────────────
    // Lectura: cualquier sesión autenticada
    // Escritura: usuario activo (docentes y admins)
    match /asistencia/{fecha} {
      allow read: if request.auth != null;
      allow write: if isActivo();
    }

    // ── Reportes de comportamiento ────────────────────────────────────────
    match /reportes/{repId} {
      allow read: if request.auth != null;
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Novedades / ausencias justificadas ───────────────────────────────
    match /novedades/{novId} {
      allow read: if request.auth != null;
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Citas ─────────────────────────────────────────────────────────────
    match /citas/{citaId} {
      allow read: if request.auth != null;
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid);
    }

    // ── Noticias / comunicados ────────────────────────────────────────────
    match /noticias/{notId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Actividades / notas ───────────────────────────────────────────────
    match /actividades/{actId} {
      allow read: if request.auth != null;
      allow create: if isActivo();
      allow update, delete: if isAdmin()
        || (isActivo() && resource.data.creadoPor == request.auth.uid)
        || (isActivo() && resource.data.docenteUid == request.auth.uid)
        || (isActivo() && resource.data.docente == miNombre());
    }

    // ── Eventos / calendario institucional ───────────────────────────────
    match /eventos/{evId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // ── Bloqueo por defecto ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
